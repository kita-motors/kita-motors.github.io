---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const featuredProjects = allProjects
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="ホーム">
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-900">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-medium text-gray-900 dark:text-gray-100 mb-6">
        きっかけを作る役をやっています
      </h1>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
        総務課長として、チームが動き出す仕組みをつくっています
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/about"
          class="px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors"
        >
          経歴・実績を見る
        </a>
        <a
          href="/contact"
          class="px-6 py-3 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-medium rounded-lg border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
        >
          お問い合わせ
        </a>
      </div>
    </div>
  </section>

  <!-- Strengths Section -->
  <section class="py-16">
    <div class="container">
      <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100 text-center mb-12">
        強み
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">DX・システム</h3>
          <p class="text-gray-600 dark:text-gray-300">
            LINE WORKS、SmartHR、Bill One等のSaaS導入から基幹システム刷新まで、POとして一貫して推進。
          </p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
          </div>
          <h3 class="text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">管理部門の立て直し</h3>
          <p class="text-gray-600 dark:text-gray-300">
            業務の棚卸しと再配置、ペーパーレス化、経理の数値整合。経理照合は1日→2時間に短縮。
          </p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">仕組みづくり</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Claude Code等のAIツールを活用し、業務支援ボットやアプリを自作。残業申請を11タップから2タップに短縮。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100">
          主なプロジェクト
        </h2>
        <a
          href="/projects"
          class="text-primary-600 dark:text-primary-400 hover:underline"
        >
          すべて見る →
        </a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tags={project.data.tags}
              date={project.data.date.toISOString()}
              url={project.data.url}
              slug={project.slug}
            />
          ))
        }
      </div>
    </div>
  </section>

</BaseLayout>
