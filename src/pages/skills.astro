---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillBadge from '../components/SkillBadge.astro';
import { skills, categoryLabels } from '../data/skills';

const technicalSkills = skills.filter((s) => s.category === 'technical');
const businessSkills = skills.filter((s) => s.category === 'business');
const managementSkills = skills.filter((s) => s.category === 'management');
---

<BaseLayout title="スキル" description="保有するスキルをカテゴリ別に紹介します。">
  <section class="py-12">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        スキル
      </h1>
      <p class="text-gray-600 dark:text-gray-300 mb-8">
        技術・業務・マネジメントの各領域で培ったスキルを紹介します。
      </p>

      <!-- Technical Skills -->
      <div class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
          <span class="w-8 h-8 bg-blue-100 dark:bg-blue-900 rounded flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </span>
          {categoryLabels.technical}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            technicalSkills.map((skill) => (
              <SkillBadge name={skill.name} level={skill.level} />
            ))
          }
        </div>
      </div>

      <!-- Business Skills -->
      <div class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
          <span class="w-8 h-8 bg-green-100 dark:bg-green-900 rounded flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </span>
          {categoryLabels.business}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            businessSkills.map((skill) => (
              <SkillBadge name={skill.name} level={skill.level} />
            ))
          }
        </div>
      </div>

      <!-- Management Skills -->
      <div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
          <span class="w-8 h-8 bg-purple-100 dark:bg-purple-900 rounded flex items-center justify-center">
            <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </span>
          {categoryLabels.management}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            managementSkills.map((skill) => (
              <SkillBadge name={skill.name} level={skill.level} />
            ))
          }
        </div>
      </div>

      <!-- Level Legend -->
      <div class="mt-12 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">
          習熟度の目安
        </h3>
        <div class="flex flex-wrap gap-4 text-sm text-gray-600 dark:text-gray-400">
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
            </div>
            <span>入門</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
            </div>
            <span>基礎</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
            </div>
            <span>実務</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-600"></div>
            </div>
            <span>上級</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
              <div class="w-2 h-2 rounded-full bg-primary-500"></div>
            </div>
            <span>熟練</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
