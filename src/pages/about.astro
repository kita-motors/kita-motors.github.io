---
import BaseLayout from '../layouts/BaseLayout.astro';
import { career, qualifications } from '../data/career';
---

<BaseLayout title="自己紹介" description="DXコンサルタント・総務マネージャーとしての経歴とスキルを紹介します。">
  <section class="py-12">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-8">
        自己紹介
      </h1>

      <!-- Profile Section -->
      <div class="mb-16">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">
            プロフィール
          </h2>
          <div class="prose max-w-none">
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              DXコンサルタント兼総務マネージャーとして、テクノロジーと組織運営の両面から企業の課題解決に取り組んでいます。
            </p>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              情報システム部門での経験を経て、現在は社内DXの推進と総務部門のマネジメントを担当。
              業務プロセスの可視化・改善から、AIチャットボットなどの新しいソリューションの導入まで、
              幅広い領域で組織の生産性向上に貢献しています。
            </p>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              「技術を使いこなせる組織づくり」をモットーに、単なるツール導入にとどまらず、
              組織文化やワークフローの変革まで見据えた支援を心がけています。
            </p>
          </div>
        </div>
      </div>

      <!-- Career Timeline -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">
          職務経歴
        </h2>
        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>
          <div class="space-y-8">
            {
              career.map((item) => (
                <div class="relative pl-12">
                  <div class="absolute left-2.5 w-3 h-3 bg-primary-500 rounded-full"></div>
                  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                      <span class="text-sm font-medium text-primary-600 dark:text-primary-400">
                        {item.period}
                      </span>
                      <span class="hidden sm:block text-gray-300 dark:text-gray-600">|</span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        {item.company}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">
                      {item.title}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300 mb-4">
                      {item.description}
                    </p>
                    {item.highlights && (
                      <ul class="space-y-2">
                        {item.highlights.map((highlight) => (
                          <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                            <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                            </svg>
                            <span>{highlight}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Qualifications -->
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">
          保有資格
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            qualifications.map((qual) => (
              <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="font-medium text-gray-900 dark:text-gray-100 mb-1">
                  {qual.name}
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  {qual.year}取得
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
