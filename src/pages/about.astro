---
import BaseLayout from '../layouts/BaseLayout.astro';
import { career, qualifications } from '../data/career';
---

<BaseLayout title="自己紹介" description="総務課長として組織マネジメントとDX推進を担当。現場経験を活かした業務改善と、AIツールを活用した自作システム開発が強みです。">
  <section class="py-12">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-8">
        自己紹介
      </h1>

      <!-- Profile Section -->
      <div class="mb-16">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">
            プロフィール
          </h2>
          <div class="prose max-w-none space-y-4">
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              小売・卸売業（従業員50〜100名）の総務課長として、組織マネジメントとDX推進を担当しています。
              営業・販売部門での現場経験を経て総務部門へ異動し、現在は4〜10名のチームを率いています。
            </p>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              課長就任以降、LINE WORKS・SmartHR・Bill Oneなどの各種SaaSの導入推進、
              基幹システム刷新プロジェクトのPO（要件定義〜受入テスト）、
              AIチャットボットや勤怠サポートボットなど業務支援システムの自作・導入など、
              幅広いDX施策を推進してきました。
              また、人事評価制度の策定や採用業務の取りまとめなど、担当領域を大幅に拡大しています。
            </p>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              マネジメント面では、課長就任後の離職者ゼロ（寿退社除く）を継続中です。
              業務効率化と組織力強化の両立を目指し、現場視点を大切にした改善活動に取り組んでいます。
            </p>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              技術面では、Claude CodeなどのAIツールを積極的に活用しています。
              プログラミングの専門家ではありませんが、要件定義・仕様設計のスキルとAIの力を組み合わせることで、
              実用的なシステムを構築できることが強みです。
            </p>
          </div>
        </div>
      </div>

      <!-- Achievements Section -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">
          主な実績
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- DX・システム -->
          <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              DX・システム
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>基幹システム刷新プロジェクトのPO（要件定義〜受入テスト）</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>SaaS導入推進（LINE WORKS、SmartHR、Bill One等）</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>AIツールを活用した業務支援システムの自作・導入</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>ベンダー選定・管理、要件定義・仕様設計</span>
              </li>
            </ul>
          </div>

          <!-- マネジメント -->
          <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              マネジメント
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>課長就任後、離職者ゼロを継続（寿退社除く）</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>4〜10名規模のチームマネジメント</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>人事評価制度の策定（外部コンサルと共同）</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>採用業務・経理業務への担当領域拡大</span>
              </li>
            </ul>
          </div>
        </div>
        <p class="mt-6 text-sm text-gray-500 dark:text-gray-400 text-center">
          フリーランスとしても、チームに入って一緒に成果を出すスタイルで働けます
        </p>
      </div>

      <!-- Career Timeline -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">
          職務経歴
        </h2>
        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>
          <div class="space-y-8">
            {
              career.map((item) => (
                <div class="relative pl-12">
                  <div class="absolute left-2.5 w-3 h-3 bg-primary-500 rounded-full"></div>
                  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                      <span class="text-sm font-medium text-primary-600 dark:text-primary-400">
                        {item.period}
                      </span>
                      <span class="hidden sm:block text-gray-300 dark:text-gray-600">|</span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        {item.company}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">
                      {item.title}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300 mb-4">
                      {item.description}
                    </p>
                    {item.highlights && (
                      <ul class="space-y-2">
                        {item.highlights.map((highlight) => (
                          <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                            <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                            </svg>
                            <span>{highlight}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Qualifications (only show if there are any) -->
      {qualifications.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">
            保有資格
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {
              qualifications.map((qual) => (
                <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
                  <h3 class="font-medium text-gray-900 dark:text-gray-100 mb-1">
                    {qual.name}
                  </h3>
                  <p class="text-sm text-gray-500 dark:text-gray-400">
                    {qual.year}取得
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
