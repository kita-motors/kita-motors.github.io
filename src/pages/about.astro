---
import BaseLayout from '../layouts/BaseLayout.astro';
import { career, qualifications } from '../data/career';
---

<BaseLayout title="自己紹介" description="総務チームのリーダーとして組織マネジメントとDX推進を担当。現場経験を活かした業務改善と、AIツールを活用した自作システム開発が強みです。">
  <section class="py-12">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-medium text-gray-900 dark:text-gray-100 mb-8">
        自己紹介
      </h1>

      <!-- Profile Section -->
      <div class="mb-16">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
          <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100 mb-6">
            きっかけを作る役
          </h2>
          <div class="prose max-w-none">
            <div class="space-y-4 text-gray-600 dark:text-gray-300 leading-relaxed">
              <p>
                総務課長として、4〜10名のチームを見ながら業務改善に取り組んでいます。
              </p>
              <p>
                課長就任後、業務の量も幅も増えましたが、働く時間は短くなりました。
              </p>
              <p>
                私がやっているのは、結局みんなをたきつけること。<br />
                自分で全部やるんじゃなく、周りが動き出すきっかけを作る役です。<br />
                そのために仕組みやツールを作ることもあります。<br />
                エンジニアの基礎を学んだ上で、AIを活用して形にしている。<br />
                言葉で説得するより、使ってもらって「これいいな」と思ってもらう方が早いので。
              </p>
              <p>
                ベンダーからは「あなたがいないと話が進まない」と言われます。<br />
                「困っていること」「こうなったらいいのに」から始めて、その先をどうしたいかを具体的に持って話をするからだと思います。<br />
                結果としてDXやAI導入になることもあれば、整理や仕組みの見直しで済むこともある。
              </p>
              <p>
                大げさなコンサルはいらないと思っています。<br />
                「ちょっと聞いてほしい」に「ちょっと答える」くらいで。
              </p>
            </div>

            <!-- 経験 -->
            <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">経験</p>
              <p class="text-gray-700 dark:text-gray-300 font-medium">
                SaaS導入（LINE WORKS・SmartHR・Bill One等）／基幹システム刷新PO／業務支援ツール自作／人事評価制度策定
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Values Section -->
      <div class="mb-16">
        <div class="bg-primary-50 dark:bg-gray-800 rounded-xl border border-primary-100 dark:border-gray-700 p-8">
          <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100 mb-6">
            大切にしていること
          </h2>
          <div class="space-y-4 text-gray-700 dark:text-gray-300 leading-relaxed">
            <p>誰かを責めるより、仕組みで解決したい。</p>
            <p>人を変えようとしない。でも「得した」「楽になった」と感じたとき、人は自分から変わる。</p>
            <p>メンバーが「できなかったことができるようになる」瞬間が一番嬉しい。</p>
            <p>止まっているより動いていたい。</p>
          </div>
        </div>
      </div>

      <!-- Style Section -->
      <div class="mb-16">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
          <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100 mb-6">
            私のスタイル
          </h2>
          <div class="text-gray-700 dark:text-gray-300 leading-relaxed">
            <p>共有しながら進める。一緒に考えて、少しずつ形にしていく。</p>
            <p class="mt-2">チームでもAIでも、この進め方は同じです。</p>
          </div>
        </div>
      </div>

      <!-- Achievements Section -->
      <div class="mb-16">
        <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100 mb-8">
          主な実績
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          <!-- DX・システム -->
          <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              DX・システム
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>基幹システム刷新プロジェクトのPO</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>SaaS導入推進（LINE WORKS、SmartHR、Bill One等）</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>AIツールを活用した業務支援システムの自作・導入</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>ベンダー選定・管理、要件定義・仕様設計</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>コーポレートサイトのリニューアル（企画・原稿・撮影）</span>
              </li>
            </ul>
          </div>

          <!-- 管理部門の立て直し -->
          <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              管理部門の立て直し
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>業務の棚卸しと再配置</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>社内申請のペーパーレス化</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>経理・基幹システムの数値整合</span>
              </li>
            </ul>
          </div>

          <!-- マネジメント -->
          <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              マネジメント
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>課長就任後、離職者ゼロを継続</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>4〜10名規模のチームマネジメント</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>人事評価制度の策定</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>採用プロセスの刷新</span>
              </li>
              <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                <span class="text-primary-500 mt-1">•</span>
                <span>経理業務のデジタル化・月次決算の短縮</span>
              </li>
            </ul>
          </div>
        </div>
        <div class="mt-6 text-center">
          <a
            href="/projects"
            class="inline-flex items-center gap-2 text-primary-600 dark:text-primary-400 hover:underline font-medium"
          >
            プロジェクトの詳細を見る
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Career Timeline -->
      <div class="mb-16">
        <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100 mb-8">
          職務経歴
        </h2>
        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>
          <div class="space-y-8">
            {
              career.map((item) => (
                <div class="relative pl-12">
                  <div class="absolute left-2.5 w-3 h-3 bg-primary-500 rounded-full"></div>
                  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                      <span class="text-sm font-medium text-primary-600 dark:text-primary-400">
                        {item.period}
                      </span>
                      <span class="hidden sm:block text-gray-300 dark:text-gray-600">|</span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        {item.company}
                      </span>
                    </div>
                    <h3 class="text-xl font-medium text-gray-900 dark:text-gray-100 mb-2">
                      {item.title}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300 mb-4">
                      {item.description}
                    </p>
                    {item.highlights && (
                      <ul class="space-y-2">
                        {item.highlights.map((highlight) => (
                          <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
                            <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                            </svg>
                            <span>{highlight}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Qualifications (only show if there are any) -->
      {qualifications.length > 0 && (
        <div>
          <h2 class="text-2xl font-medium text-gray-900 dark:text-gray-100 mb-8">
            保有資格
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {
              qualifications.map((qual) => (
                <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
                  <h3 class="font-medium text-gray-900 dark:text-gray-100 mb-1">
                    {qual.name}
                  </h3>
                  <p class="text-sm text-gray-500 dark:text-gray-400">
                    {qual.year}取得
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
