---
interface Props {
  name: string;
  level: 1 | 2 | 3 | 4 | 5;
}

const { name, level } = Astro.props;

const levelLabels = ['入門', '基礎', '実務', '上級', '熟練'];
---

<div class="flex items-center gap-3 p-3 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
  <span class="font-medium text-gray-900 dark:text-gray-100">{name}</span>
  <div class="flex items-center gap-1 ml-auto">
    {
      [1, 2, 3, 4, 5].map((i) => (
        <div
          class:list={[
            'w-2 h-2 rounded-full',
            i <= level
              ? 'bg-primary-500'
              : 'bg-gray-200 dark:bg-gray-600',
          ]}
        />
      ))
    }
    <span class="ml-2 text-xs text-gray-500 dark:text-gray-400">
      {levelLabels[level - 1]}
    </span>
  </div>
</div>
